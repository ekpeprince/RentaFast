
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().role == 'admin';
    }

    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             getUserData().role == role;
    }

    // 1. Users Profile
    match /users/{userId} {
      allow get: if true; 
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      
      match /favorites/{propertyId} {
        allow read, write: if isOwner(userId);
      }
    }

    // 2. Properties
    match /properties/{propertyId} {
      allow read: if true; 
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'favoriteCount', 'averageRating', 'reviewCount']);
      allow create, delete: if hasRole('landlord') || isAdmin();
      allow update: if hasRole('landlord') || isAdmin();

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.reviewerId == request.auth.uid;
        allow delete, update: if isAdmin();
      }
    }

    // 3. Chats
    match /chats/{chatId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participants);
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants);
      
      match /messages/{messageId} {
        allow read, create: if isSignedIn() && 
                      get(/databases/$(database)/documents/chats/$(chatId)).data.participants != null &&
                      (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      }
    }

    // 4. Applications
    match /applications/{applicationId} {
      // Simplified read permission for better list query matching
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.tenantId || 
        request.auth.uid == resource.data.landlordId ||
        isAdmin()
      );
      allow create: if isSignedIn() && request.resource.data.tenantId == request.auth.uid;
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid == resource.data.landlordId);
    }
  }
}
