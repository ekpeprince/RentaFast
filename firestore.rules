rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Safely check for a user's role document.
    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Rules ---

    // 1. User Profiles
    match /users/{userId} {
      // Profiles are publicly readable for marketplace trust
      allow get: if true;
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      
      match /favorites/{propertyId} {
        allow read, write: if isOwner(userId);
      }
    }

    // 2. Property Listings
    match /properties/{propertyId} {
      allow read: if true;
      // Allow public to update specific stats for engagement tracking
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'favoriteCount', 'averageRating', 'reviewCount']);
      
      allow create: if isSignedIn();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.landlordId == request.auth.uid);

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.reviewerId == request.auth.uid);
      }
    }

    // 3. Conversations (Chats)
    match /chats/{chatId} {
      allow read, update: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn();
      
      match /messages/{messageId} {
        allow read, create: if isSignedIn() && 
                      (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      }
    }

    // 4. Rental Applications (Leads)
    match /applications/{applicationId} {
      // Explicit read rule for individual documents and listings.
      // For listings, the query MUST be filtered by landlordId or tenantId to pass this rule.
      allow read: if isAdmin() || (isSignedIn() && (
        resource.data.tenantId == request.auth.uid || 
        resource.data.landlordId == request.auth.uid
      ));
      
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.landlordId);
      allow delete: if isAdmin();
    }
  }
}
