
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Checks if the user has a specific role in their Firestore document
    function hasRole(role) {
      return isSignedIn() && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    function isAdmin() {
      // Robust check for admin role
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Rules ---

    // 1. User Profiles
    match /users/{userId} {
      // Profiles are readable by anyone (for property details/reviews)
      allow get: if true;
      // Listing all users is restricted to admins
      allow list: if isAdmin();
      // Users can manage their own profiles
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      
      // Favorites sub-collection
      match /favorites/{propertyId} {
        allow read, write: if isOwner(userId);
      }
    }

    // 2. Property Listings
    match /properties/{propertyId} {
      // Everyone can view properties
      allow read: if true;
      // Allow metadata updates (views, favs) from any visitor
      // We check that ONLY the specified keys are being changed
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'favoriteCount', 'averageRating', 'reviewCount']);
      
      // Landlords and admins can manage listings
      allow create: if hasRole('landlord') || isAdmin();
      allow update: if (isSignedIn() && resource.data.landlordId == request.auth.uid) || isAdmin();
      allow delete: if (isSignedIn() && resource.data.landlordId == request.auth.uid) || isAdmin();

      // Property Reviews
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.reviewerId == request.auth.uid;
        allow delete, update: if isAdmin() || (isSignedIn() && resource.data.reviewerId == request.auth.uid);
      }
    }

    // 3. Conversations (Chats)
    match /chats/{chatId} {
      // Participants can view and update chat metadata
      allow read, update: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participants);
      
      match /messages/{messageId} {
        // Must be a participant of the parent chat
        allow read, create: if isSignedIn() && 
                      get(/databases/$(database)/documents/chats/$(chatId)).data.participants != null &&
                      (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      }
    }

    // 4. Rental Applications (Leads)
    match /applications/{applicationId} {
      // CRITICAL: For 'list' to work, the query MUST filter by tenantId or landlordId.
      // This rule ensures that a user can only see applications they are part of.
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.tenantId || 
        request.auth.uid == resource.data.landlordId ||
        isAdmin()
      );
      
      // Tenants create applications
      allow create: if isSignedIn() && request.resource.data.tenantId == request.auth.uid;
      
      // Landlords and admins update status
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.landlordId || 
        isAdmin()
      );
      
      allow delete: if isAdmin();
    }
  }
}
