
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(role) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)) && getUserData().role == role;
    }
    
    function isAdmin() {
      return hasRole('admin');
    }

    // 1. Users Profile
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      
      // User's own favorites
      match /favorites/{propertyId} {
        allow get, list, write: if isOwner(userId);
      }
    }

    // 2. Properties
    match /properties/{propertyId} {
      allow get, list: if true; 
      allow write: if hasRole('landlord') || isAdmin();

      // Reviews
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.reviewerId == request.auth.uid;
        allow delete, update: if isAdmin();
      }
    }

    // 3. Chats
    match /chats/{chatId} {
      allow get: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow list: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() 
                      && ('participants' in request.resource.data)
                      && (request.auth.uid in request.resource.data.participants);
      allow update: if isSignedIn() 
                      && (request.auth.uid in resource.data.participants);
      
      match /messages/{messageId} {
        allow read, create: if isSignedIn() 
                      && get(/databases/$(database)/documents/chats/$(chatId)).data.participants != null
                      && (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      }
    }

    // 4. Applications
    match /applications/{applicationId} {
      allow get: if isSignedIn() && (request.auth.uid == resource.data.tenantId || request.auth.uid == resource.data.landlordId);
      allow list: if isSignedIn() && (request.auth.uid == resource.data.tenantId || request.auth.uid == resource.data.landlordId);
      allow create: if isSignedIn() && request.resource.data.tenantId == request.auth.uid;
      allow update: if isSignedIn() && (request.auth.uid == resource.data.landlordId || isAdmin());
    }
  }
}
