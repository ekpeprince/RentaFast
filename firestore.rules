rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isLandlord() {
      return isSignedIn() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'landlord';
    }

    match /users/{userId} {
      allow read, update, delete: if isOwner(userId);
      allow create: if isOwner(userId) && request.resource.data.id == userId && request.resource.data.role in ['tenant', 'landlord'];
    }

    match /properties/{propertyId} {
      allow read, list: if true;
      allow create: if isLandlord() && request.resource.data.landlordId == request.auth.uid;
      allow update, delete: if isLandlord() && resource.data.landlordId == request.auth.uid;
    }
  }
}
