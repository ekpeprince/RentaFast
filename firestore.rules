
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function hasRole(role) {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == role;
    }

    // 1. Users Profile
    match /users/{userId} {
      // Public read for profile info (names, badges, landlord verification)
      allow get: if true; 
      // Only admins can list all users
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      
      // User's own favorites
      match /favorites/{propertyId} {
        allow read, write: if isOwner(userId);
      }
    }

    // 2. Properties
    match /properties/{propertyId} {
      allow read: if true; 
      
      // Allow public increment of viewCount and other stats
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'favoriteCount', 'averageRating', 'reviewCount']);
      
      // Authorized writes for landlords/admins
      allow create, delete: if hasRole('landlord') || isAdmin();
      allow update: if hasRole('landlord') || isAdmin();

      // Reviews
      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn() && request.resource.data.reviewerId == request.auth.uid;
        allow delete, update: if isAdmin();
      }
    }

    // 3. Chats
    match /chats/{chatId} {
      allow read: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn() && (request.auth.uid in request.resource.data.participants);
      allow update: if isSignedIn() && (request.auth.uid in resource.data.participants);
      
      match /messages/{messageId} {
        allow read, create: if isSignedIn() && 
                      get(/databases/$(database)/documents/chats/$(chatId)).data.participants != null &&
                      (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      }
    }

    // 4. Applications
    match /applications/{applicationId} {
      // Use 'read' to cover both get and list. 
      // Landlords/Tenants can list their own via filtered queries. Admins can list all.
      allow read: if isSignedIn() && (
        isAdmin() || 
        request.auth.uid == resource.data.tenantId || 
        request.auth.uid == resource.data.landlordId
      );
      allow create: if isSignedIn() && request.resource.data.tenantId == request.auth.uid;
      allow update: if isSignedIn() && (isAdmin() || request.auth.uid == resource.data.landlordId);
    }
  }
}
