rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Safely check for a user's role. Using exists() first is critical to avoid errors on missing docs.
    function getRole() {
      let userDoc = /databases/$(database)/documents/users/$(request.auth.uid);
      return exists(userDoc) ? get(userDoc).data.role : 'unverified';
    }

    function isAdmin() {
      return isSignedIn() && getRole() == 'admin';
    }

    function isLandlord() {
      return isSignedIn() && getRole() == 'landlord';
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    // --- Rules ---

    // 1. User Profiles
    match /users/{userId} {
      allow get: if true;
      allow list: if isAdmin();
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) || isAdmin();
      
      match /favorites/{propertyId} {
        allow read, write: if isOwner(userId);
      }
    }

    // 2. Property Listings
    match /properties/{propertyId} {
      allow read: if true;
      allow update: if request.resource.data.diff(resource.data).affectedKeys().hasOnly(['viewCount', 'favoriteCount', 'averageRating', 'reviewCount']);
      
      allow create: if isLandlord() || isAdmin();
      allow update, delete: if isAdmin() || (isSignedIn() && resource.data.landlordId == request.auth.uid);

      match /reviews/{reviewId} {
        allow read: if true;
        allow create: if isSignedIn();
        allow update, delete: if isAdmin() || (isSignedIn() && resource.data.reviewerId == request.auth.uid);
      }
    }

    // 3. Conversations (Chats)
    match /chats/{chatId} {
      allow read, update: if isSignedIn() && (request.auth.uid in resource.data.participants);
      allow create: if isSignedIn();
      
      match /messages/{messageId} {
        allow read, create: if isSignedIn() && 
                      (request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.participants);
      }
    }

    // 4. Rental Applications (Leads)
    match /applications/{applicationId} {
      // Landlords and tenants see their own documents; Admins see all.
      allow get: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.tenantId || 
        request.auth.uid == resource.data.landlordId
      );
      
      // For collection queries (list), the query must be filtered by landlordId or tenantId
      // UNLESS the user is an admin.
      allow list: if isSignedIn() && (
        isAdmin() ||
        request.auth.uid == resource.data.landlordId ||
        request.auth.uid == resource.data.tenantId
      );
      
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && request.auth.uid == resource.data.landlordId);
      allow delete: if isAdmin();
    }
  }
}