
{
  "entities": {
    "User": {
      "title": "User",
      "type": "object",
      "description": "Represents a user in the RentaFast application, storing their role and potentially other profile information.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Unique identifier for the user, matching their Firebase Auth UID."
        },
        "role": {
          "type": "string",
          "description": "The user's role in the application (either 'landlord', 'tenant', or 'admin').",
          "enum": ["landlord", "tenant", "admin"]
        },
        "displayName": {
          "type": "string",
          "description": "The user's preferred public name."
        },
        "phoneNumber": {
          "type": "string",
          "description": "Contact phone number for the user."
        },
        "photoURL": {
          "type": "string",
          "description": "URL to the user's profile picture."
        },
        "isVerified": {
          "type": "boolean",
          "description": "Whether the user has been verified by RentaFast admins.",
          "default": false
        }
      },
      "required": [
        "id",
        "role"
      ]
    },
    "Property": {
      "title": "Property",
      "type": "object",
      "description": "Represents a property listing in the RentaFast application.",
      "properties": {
        "landlordId": {
          "type": "string",
          "description": "Reference to the User who owns this property."
        },
        "title": {
          "type": "string",
          "description": "The title of the property listing."
        },
        "location": {
          "type": "string",
          "description": "The location of the property."
        },
        "price": {
          "type": "number",
          "description": "The rental price of the property."
        },
        "description": {
          "type": "string",
          "description": "A detailed description of the property."
        },
        "type": {
          "type": "string",
          "enum": ["Flat", "Duplex", "Short-let", "Self-con", "Penthouse"]
        },
        "imageUrls": {
          "type": "array",
          "items": { "type": "string" }
        },
        "beds": { "type": "number" },
        "baths": { "type": "number" },
        "amenities": {
          "type": "array",
          "items": { "type": "string" }
        },
        "period": { "type": "string", "enum": ["yr", "mo"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": [
        "landlordId",
        "title",
        "location",
        "price",
        "description"
      ]
    },
    "Chat": {
      "title": "Chat",
      "type": "object",
      "description": "Represents a conversation between a tenant and a landlord.",
      "properties": {
        "participants": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Array of user UIDs involved in the chat."
        },
        "propertyId": {
          "type": "string",
          "description": "The ID of the property this chat is regarding."
        },
        "propertyTitle": {
          "type": "string"
        },
        "lastMessage": {
          "type": "string"
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Message": {
      "title": "Message",
      "type": "object",
      "description": "A single message within a chat.",
      "properties": {
        "senderId": {
          "type": "string"
        },
        "text": {
          "type": "string"
        },
        "createdAt": {
          "type": "string",
          "format": "date-time"
        }
      }
    },
    "Favorite": {
      "title": "Favorite",
      "type": "object",
      "description": "A saved property reference for a specific user.",
      "properties": {
        "propertyId": { "type": "string" },
        "savedAt": { "type": "string", "format": "date-time" }
      }
    },
    "Application": {
      "title": "Application",
      "type": "object",
      "description": "A formal rental application for a property.",
      "properties": {
        "propertyId": { "type": "string" },
        "propertyTitle": { "type": "string" },
        "landlordId": { "type": "string" },
        "tenantId": { "type": "string" },
        "tenantName": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["Pending", "Reviewing", "Tour Scheduled", "Accepted", "Rejected"]
        },
        "moveInDate": { "type": "string" },
        "occupants": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["propertyId", "landlordId", "tenantId", "status"]
    }
  },
  "auth": {
    "providers": [
      "password"
    ]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": {
        "$ref": "#/entities/User"
      },
      "description": "Stores user profiles."
    },
    "/users/{userId}/favorites/{propertyId}": {
      "schema": {
        "$ref": "#/entities/Favorite"
      },
      "description": "Stores a user's favorited properties."
    },
    "/properties/{propertyId}": {
      "schema": {
        "$ref": "#/entities/Property"
      },
      "description": "Stores property listings."
    },
    "/chats/{chatId}": {
      "schema": {
        "$ref": "#/entities/Chat"
      },
      "description": "Stores conversation metadata."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": {
        "$ref": "#/entities/Message"
      },
      "description": "Stores individual messages within a conversation."
    },
    "/applications/{applicationId}": {
      "schema": {
        "$ref": "#/entities/Application"
      },
      "description": "Stores formal rental applications."
    }
  }
}
